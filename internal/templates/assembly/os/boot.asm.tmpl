; [[.Name]] — x86 BIOS Bootloader (512 bytes)
[bits 16]
[org 0x7c00]

start:
    mov si, msg
    call print_string

    jmp $ ; Infinite loop

print_string:
    mov ah, 0x0e
.loop:
    lodsb
    test al, al
    jz .done
    int 0x10
    jmp .loop
.done:
    ret

msg db "Hello from [[.Name]] OS!", 13, 10, 0

times 510-($-$$) db 0
dw 0xaa55 ; Boot signature
