#include <stdio.h>
#include <unistd.h>
#include <sys/utsname.h>

int main(void) {
    printf("OS Info for [[ .Name ]]\n");
    
    struct utsname info;
    if (uname(&info) == 0) {
        printf("Sysname:  %s\n", info.sysname);
        printf("Release:  %s\n", info.release);
        printf("Version:  %s\n", info.version);
        printf("Machine:  %s\n", info.machine);
    }
    
    printf("PID: %d\n", getpid());
    return 0;
}
