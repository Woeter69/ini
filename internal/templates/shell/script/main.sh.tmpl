#!/usr/bin/env bash
set -euo pipefail

# [[ .Name ]] — CLI Tool / Script
# Generated by ini

usage() {
    echo "Usage: $0 [options]"
    echo "Options:"
    echo "  -h, --help      Show this help message"
    echo "  -v, --version   Show version"
}

main() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "[[ .Name ]] v0.1.0"
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done

    echo "Running [[ .Name ]] script..."
}

main "$@"
