#!/usr/bin/env bash
set -euo pipefail

# [[ .Name ]] — Networking Utility Script
# Generated by ini

main() {
    echo "Network Diagnostics for [[ .Name ]]"
    
    local host="google.com"
    echo "Pinging ${host}..."
    if ping -c 1 "${host}" &> /dev/null; then
        echo "Success: ${host} is reachable."
    else
        echo "Failure: ${host} is unreachable."
    fi
}

main "$@"
