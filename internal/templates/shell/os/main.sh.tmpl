#!/usr/bin/env bash
set -euo pipefail

# [[ .Name ]] — System & OS Management Script
# Generated by ini

main() {
    echo "System Information for [[ .Name ]]"
    echo "OS: $(uname -s)"
    echo "Kernel: $(uname -r)"
    echo "Uptime: $(uptime -p)"
    echo "Memory Usage:"
    free -h
}

main "$@"
