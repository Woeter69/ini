import { Database } from "bun:sqlite";

console.log("Welcome to {{ .Name }} - Bun SQLite Database");

const db = new Database(":memory:");
console.log("Successfully connected to in-memory SQLite database.");

db.run("CREATE TABLE users (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT)");
console.log("Created table 'users'.");

const insertUser = db.prepare("INSERT INTO users (name) VALUES ($name)");
insertUser.run({ $name: "User from {{ .Name }}" });
console.log("Inserted sample user.");

const users = db.query("SELECT * FROM users").all();
console.log("\nQuery Results:", users);
