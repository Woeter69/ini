console.log("Welcome to [[ .Name ]] - Bun Networking");

const server = Bun.serve({
  port: 3000,
  fetch(request) {
    const url = new URL(request.url);
    if (url.pathname === "/") return new Response("Welcome to [[ .Name ]] Network Server!");
    if (url.pathname === "/api") return Response.json({ message: "Hello from Bun API" });
    return new Response("404 Not Found", { status: 404 });
  },
});

console.log(`Listening on http://localhost:${server.port}...`);
