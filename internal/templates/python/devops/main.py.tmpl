import boto3
from botocore.exceptions import ClientError

def main():
    print("Welcome to {{ .Name }} - DevOps & Infrastructure")
    print("Using Boto3 SDK")
    
    # Initialize S3 client (requires valid AWS credentials in environment)
    s3 = boto3.client('s3')
    
    try:
        # Try to list buckets as a sanity check
        response = s3.list_buckets()
        print("\nSuccessfully authenticated with AWS.")
        print(f"Found {len(response.get('Buckets', []))} buckets.")
    except ClientError as e:
        if e.response['Error']['Code'] == 'AuthFailure':
            print("\nAWS credentials not configured. Please run `aws configure`.")
        else:
            print(f"\nCould not connect: {e}")
    except Exception as e:
        print("\nAWS environment not fully configured.")
        print("Set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY to connect.")

if __name__ == "__main__":
    main()
