from web3 import Web3

def main():
    print("Welcome to {{ .Name }} - Blockchain & Web3")
    
    # Connect to Ethereum Mainnet (public infura gateway)
    w3 = Web3(Web3.HTTPProvider('https://cloudflare-eth.com'))
    
    print("\nConnecting to Ethereum network...")
    if w3.is_connected():
        print(f"Successfully connected to Cloudflare public node!")
        block_num = w3.eth.block_number
        print(f"Current Block Number: {block_num}")
        
    else:
        print("Failed to connect to the Ethereum network.")

if __name__ == "__main__":
    main()
