#include <iostream>
#include <vector>
#include <string>
#include <string_view>

void print_usage(std::string_view prog_name) {
    std::cout << "Usage: " << prog_name << " [options]\n"
              << "Options:\n"
              << "  --help     Show this message\n"
              << "  --version  Show project version" << std::endl;
}

int main(int argc, char* argv[]) {
    std::vector<std::string_view> args(argv, argv + argc);

    if (args.size() < 2) {
        print_usage(args[0]);
        return 0;
    }

    if (args[1] == "--help") {
        print_usage(args[0]);
    } else if (args[1] == "--version") {
        std::cout << "[[ .Name ]] version 0.1.0" << std::endl;
    } else {
        std::cerr << "Unknown option: " << args[1] << std::endl;
        return 1;
    }

    return 0;
}
