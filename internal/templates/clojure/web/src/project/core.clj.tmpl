(ns [[ .Name ]].core
  (:require [reitit.ring :as ring]
            [ring.adapter.jetty :as jetty]))

(def app
  (ring/ring-handler
    (ring/router
      ["/" {:get (fn [_] {:status 200 :body "Hello from [[ .Name ]] (Reitit Web Server)!"})}])
    (ring/create-default-handler)))

(defn -main [& args]
  (println "Starting [[ .Name ]] web server on port 3000...")
  (jetty/run-jetty app {:port 3000 :join? false}))
